# External upstream repository paths.
VGGT_OMEGA_REPO=external/vggt-omega
MEDICALSAM3_REPO=external/Medical-SAM3
MANUAL_CORRESPONDENCES_REPO=external/manual-correspondences

# Output/cache locations.
REGISTRATION_OUTPUT_DIR=outputs
REGISTRATION_CACHE_DIR=cache
VGGT_OMEGA_CACHE_DIR=cache/vggt-omega
MEDICALSAM3_CACHE_DIR=cache/medicalsam3
MANUAL_CORRESPONDENCES_DATA_DIR=external/manual-correspondences/examples

# Checkpoint examples. Keep real checkpoints outside Git.
VGGT_OMEGA_CHECKPOINT=checkpoints/vggt-omega/vggt_omega_1b_512.pt
MEDICALSAM3_CHECKPOINT=checkpoints/medicalsam3/checkpoint.pt

# Runtime defaults used by the demo.
REGISTRATION_DEVICE=cuda
VGGT_OMEGA_IMAGE_RESOLUTION=512
